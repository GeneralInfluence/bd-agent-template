# ── Required ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=        # From @BotFather. Must have Group Privacy OFF.
SUPABASE_URL=              # https://xxxxx.supabase.co
SUPABASE_ANON_KEY=         # Supabase anon/public API key
ANTHROPIC_API_KEY=         # Only used for LLM qualification on @mentions

# ── BD Steward ───────────────────────────────────────────────────
BD_STEWARD_TELEGRAM_ID=    # Telegram user ID of the BD steward
ORG_NAME=                  # Your org's name — used in bot greetings

# ── Ditto Knowledge Graph (optional but recommended) ─────────────
DITTO_API_KEY=             # Bearer token from heyditto.ai — enables contribution tracking

# ── Reminders / Cron ─────────────────────────────────────────────
STEWARD_TZ=America/Los_Angeles   # IANA timezone for daily/weekly cron jobs (default: America/Los_Angeles)

# ── PrismBOT (optional) ──────────────────────────────────────────
PRISM_API_URL=             # PrismBOT API base URL
PRISM_API_KEY=             # PrismBOT API key

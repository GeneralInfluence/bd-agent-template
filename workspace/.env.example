# BD Agent — Environment Variables
# Copy this to .env and fill in your values.
# For Pinata deployments, set these as Secrets in the Pinata dashboard instead.

# ── Required ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=        # From @BotFather. Must have Group Privacy OFF.
SUPABASE_URL=              # https://xxxxx.supabase.co
SUPABASE_ANON_KEY=         # Supabase anon/public API key
ANTHROPIC_API_KEY=         # Used for LLM qualification on @mentions

# ── Your Org ─────────────────────────────────────────────────────
ORG_NAME=                  # Your organization's name — used in bot greetings

# ── BD Steward ───────────────────────────────────────────────────
BD_STEWARD_TELEGRAM_ID=    # Telegram user ID — must DM the bot once first
STEWARD_TZ=America/Los_Angeles   # IANA timezone for daily/weekly cron jobs

# ── Ditto Knowledge Graph (optional) ─────────────────────────────
DITTO_API_KEY=             # Bearer token from heyditto.ai — contribution tracking

# ── PrismBOT (optional) ──────────────────────────────────────────
PRISM_API_URL=             # PrismBOT API base URL
PRISM_API_KEY=             # PrismBOT API key
